# ============================================
# Exam Attendance Tracking - Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# MongoDB Connection
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database
# For local MongoDB: mongodb://localhost:27017/exam-tracking
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/exam-tracking

# JWT Secret (generate a strong random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Backend Port
PORT=3000

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Examinations Office <your-email@gmail.com>

# Frontend API URL (for Docker deployment, use the backend service name or server IP)
# For local Docker: http://backend:3000
# For deployed server: http://your-server-ip:3000 or https://api.yourdomain.com
VITE_API_URL=http://localhost:3000

# Optional: Local MongoDB credentials (if using docker-compose mongodb)
# MONGO_ROOT_USERNAME=admin
# MONGO_ROOT_PASSWORD=password